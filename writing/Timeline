<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>The Timeline | Two Word Smiths</title>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300;500;700&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Comfortaa', sans-serif; background-color: #0b0c10; color: #c5c6c7; padding: 40px 20px; line-height: 1.8; }
        .container { max-width: 800px; margin: 0 auto; background: rgba(31, 40, 51, 0.6); padding: 40px; border-radius: 16px; backdrop-filter: blur(8px); border: 1px solid rgba(255, 255, 255, 0.05); }
        nav a { color: #66fcf1; text-decoration: none; font-size: 0.9rem; letter-spacing: 1px; }
        nav a:hover { text-decoration: underline; }
        h1 { color: #ffffff; font-size: 2.5rem; margin-top: 30px; margin-bottom: 20px; border-bottom: 1px solid rgba(102, 252, 241, 0.2); padding-bottom: 10px; }
        
        /* Calendar Wrapper to ensure responsiveness */
        .calendar-wrapper {
            position: relative;
            padding-bottom: 75%; /* Aspect Ratio */
            height: 0;
            overflow: hidden;
            border-radius: 8px;
            border: 1px solid rgba(102, 252, 241, 0.1);
            margin-top: 20px;
        }
        .calendar-wrapper iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            border: 0;
        }
    </style>
</head>
